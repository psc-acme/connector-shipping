{
    "name": "psc-acme/connector-shipping",
    "description": "Package connector-shipping for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ConnectorShipping\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^6.0",
        "symfony/messenger": "^7.0",
        "symfony/validator": "^7.0",
        "symfony/lock": "^7.0",
        "league/flysystem": "^3.0",
        "psc-acme/decoder-product": "^1.0",
        "psc-acme/util-inventory": "^1.0",
        "psc-acme/proxy-inventory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan-symfony": "^1.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}